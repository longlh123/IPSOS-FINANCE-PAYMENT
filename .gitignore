# ============================================================
# FRONTEND (React / Node)
# ============================================================
frontend/node_modules/
frontend/build/
frontend/coverage/
frontend/.pnp
frontend/.pnp.js
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

# ============================================================
# BACKEND (Laravel / PHP)
# ============================================================
backend/vendor/
backend/node_modules/

# Laravel env — only .env.example is safe to commit
backend/.env
backend/.env.*
!backend/.env.example

# Laravel generated / runtime files
backend/bootstrap/cache/*.php
backend/storage/logs/
backend/storage/framework/cache/
backend/storage/framework/sessions/
backend/storage/framework/views/
backend/storage/app/public/
backend/public/hot
backend/public/storage

# ============================================================
# PRIVATE KEYS & CERTIFICATES — never commit
# ============================================================
*.pem
*.key
*.p12
*.pfx
backend/storage/keys/

# ============================================================
# DATABASE BACKUPS
# ============================================================
database/
*.sql
*.sqlite
*.db

# ============================================================
# DOCKER
# ============================================================
docker-compose.override.yml

# ============================================================
# OS / IDE
# ============================================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Root-level leftovers (legacy)
/node_modules
/coverage
/build
